# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real tokens.

# Hugging Face token (required to download gated models like Llama)
HF_TOKEN=hf_your_token_here

# Optional: override model cache directory (default: ~/.cache/huggingface)
# HF_HOME=/path/to/large/storage/.cache/huggingface

# Optional: point to local model copy instead of downloading
# LOCAL_MODEL_PATH=/path/to/Llama-3.2-3B-Instruct

# Optional: Weights & Biases (not used by default)
# WANDB_API_KEY=your_key_here
# WANDB_PROJECT=refusal-decay
